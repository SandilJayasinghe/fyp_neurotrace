{
  "name": "tremora",
  "private": true,
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.tremora.app",
    "productName": "Tremora",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "SandilJayasinghe",
      "repo": "fyp_neurotrace"
    }
  },
  "dependencies": {
    "@radix-ui/react-progress": "latest",
    "@radix-ui/react-tooltip": "latest",
    "@serialport/bindings-cpp": "^13.0.1",
    "axios": "latest",
    "framer-motion": "latest",
    "lucide-react": "latest",
    "node-hid": "^3.3.0",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "^3.8.0",
    "uiohook-napi": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "autoprefixer": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "latest",
    "electron-builder": "^24.0.0",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "postcss": "latest",
    "tailwindcss": "latest",
    "vite": "latest",
    "wait-on": "latest"
  }
}